<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="referrer" content="no-referrer">
    <title><%= news.title %> - 59 Haber Kutusu</title>
    <meta name="description" content="<%= news.description %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <!-- Top Bar -->
    <div class="topbar">
        <div class="container topbar-inner">
            <span class="topbar-date" id="currentDate"></span>
            <div class="topbar-social">
                <a href="https://www.facebook.com/people/Habe59/61581999440146/" target="_blank" aria-label="Facebook"><svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
                <a href="https://www.instagram.com/59haberkutusu/" target="_blank" aria-label="Instagram"><svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
                <a href="https://wa.me/905334773639" target="_blank" aria-label="WhatsApp İhbar Hattı"><svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header class="header">
        <div class="container header-inner">
            <a href="/" class="logo">
                <img src="/logo.png" alt="59 Haber Kutusu" class="logo-img">
            </a>
            <button class="menu-toggle" id="menuToggle" aria-label="Menü">
                <span></span><span></span><span></span>
            </button>
            <nav class="nav" id="mainNav">
                <a href="/" class="nav-link">Ana Sayfa</a>
                <a href="/kategori/son-dakika" class="nav-link">Son Dakika</a>
                <a href="/kategori/gundem" class="nav-link">Gündem</a>
                <a href="/kategori/ekonomi" class="nav-link">Ekonomi</a>
                <a href="/kategori/spor" class="nav-link">Spor</a>
                <a href="/kategori/siyaset" class="nav-link">Siyaset</a>
                <a href="/kategori/yasam" class="nav-link">Yaşam</a>
            </nav>
        </div>
    </header>
    <%- include('partials/side-ads') %>

    <!-- Breadcrumb -->
    <div class="detail-breadcrumb">
        <div class="container">
            <a href="/">Ana Sayfa</a>
            <span class="bc-sep">/</span>
            <% const catSlugMap = { 'Gündem': 'gundem', 'Ekonomi': 'ekonomi', 'Spor': 'spor', 'Siyaset': 'siyaset', 'Yaşam': 'yasam', 'Sağlık': 'saglik' }; %>
            <a href="/kategori/<%= catSlugMap[news.category] || news.category.toLowerCase() %>"><%= news.category %></a>
            <span class="bc-sep">/</span>
            <span class="bc-current"><%= news.title.length > 50 ? news.title.substring(0, 50) + '...' : news.title %></span>
        </div>
    </div>

    <!-- Article -->
    <main class="detail-main">
        <div class="container">
            <div class="detail-layout">
                <article class="detail-article">
                    <div class="detail-header">
                        <span class="category-badge"><%= news.category %></span>
                        <h1 class="detail-title"><%= news.title %></h1>
                        <div class="detail-meta">
                            <span class="detail-date">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <%= news.createdAt.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', weekday: 'long' }) %>
                            </span>
                            <span class="detail-date">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
                                <%= Number(news.viewCount || 0).toLocaleString('tr-TR') %> okunma
                            </span>
                        </div>
                    </div>

                    <% if (news.image) { %>
                    <div class="detail-image">
                        <img src="<%= news.image %>" alt="<%= news.title %>">
                    </div>
                    <% } %>

                    <div class="detail-body">
                        <p class="detail-lead"><%= news.description %></p>
                        <% if (news.content) { %>
                            <div class="detail-content"><%- news.content.replace(/\n/g, '<br>') %></div>
                        <% } %>
                    </div>

                    <!-- Share -->
                    <div class="detail-share">
                        <span class="share-label">Paylaş:</span>
                        <a href="https://www.facebook.com/sharer/sharer.php?u=" target="_blank" class="share-btn share-fb">Facebook</a>
                        <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(news.title) %>" target="_blank" class="share-btn share-tw">Twitter</a>
                        <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(news.title) %>" target="_blank" class="share-btn share-wa">WhatsApp</a>
                    </div>

                    <!-- Prev / Next Navigation -->
                    <div class="detail-nav">
                        <% if (prev) { %>
                        <a href="/haber/<%= prev.slug || prev._id %>" class="nav-prev">
                            <span class="nav-label">&larr; Önceki Haber</span>
                            <span class="nav-title"><%= prev.title %></span>
                        </a>
                        <% } else { %>
                        <div></div>
                        <% } %>
                        <% if (next) { %>
                        <a href="/haber/<%= next.slug || next._id %>" class="nav-next">
                            <span class="nav-label">Sonraki Haber &rarr;</span>
                            <span class="nav-title"><%= next.title %></span>
                        </a>
                        <% } %>
                    </div>
                </article>

                <!-- Sidebar -->
                <aside class="detail-sidebar">
                    <div class="sidebar-section">
                        <h3 class="sidebar-title"><%= news.category %> Haberleri</h3>
                        <% if (related.length > 0) { %>
                            <% related.forEach(item => { %>
                            <a href="/haber/<%= item.slug || item._id %>" class="sidebar-item">
                                <% if (item.image) { %>
                                <img src="<%= item.image %>" alt="<%= item.title %>" class="sidebar-img">
                                <% } %>
                                <div class="sidebar-info">
                                    <h4><%= item.title %></h4>
                                    <span class="sidebar-date"><%= item.createdAt.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long' }) %></span>
                                </div>
                            </a>
                            <% }) %>
                        <% } else { %>
                            <p style="font-size:13px;color:var(--gray-600);">Bu kategoride başka haber yok.</p>
                        <% } %>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <img src="/logo.png" alt="59 Haber Kutusu" class="footer-logo">
                    <p>Tekirdağ ve Trakya'nın güvenilir haber kaynağı.</p>
                </div>
                <div class="footer-links">
                    <h4>Kategoriler</h4>
                    <a href="/kategori/gundem">Gündem</a><a href="/kategori/ekonomi">Ekonomi</a><a href="/kategori/spor">Spor</a>
                    <a href="/kategori/siyaset">Siyaset</a><a href="/kategori/yasam">Yaşam</a><a href="/kategori/saglik">Sağlık</a>
                </div>
                <div class="footer-links">
                    <h4>Kurumsal</h4>
                    <a href="/hakkinda">Hakkında</a>
                    <a href="/kunye">Künye</a>
                    <a href="/telif-hakki">Telif Hakkı</a>
                </div>
                <div class="footer-links">
                    <h4>İletişim</h4>
                    <p>Tekirdağ</p>
                    <p>+90 533 477 36 39</p>
                    <a href="https://wa.me/905334773639" target="_blank" style="color:#4CAF50;font-weight:600;">WhatsApp İhbar Hattı</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 <strong>59 Haber Kutusu</strong>. Tüm Hakları Saklıdır.</p>
            </div>
        </div>
    </footer>

    <script>
        const months = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
        const days = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
        const now = new Date();
        document.getElementById('currentDate').textContent =
            days[now.getDay()] + ', ' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();
        document.getElementById('menuToggle').addEventListener('click', function() {
            document.getElementById('mainNav').classList.toggle('open');
            this.classList.toggle('active');
        });
    </script>
</body>
</html>
