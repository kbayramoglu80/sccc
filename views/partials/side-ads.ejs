<% const leftList = Array.isArray(leftAds) ? leftAds : []; %>
<% const rightList = Array.isArray(rightAds) ? rightAds : []; %>
<% const topList = Array.isArray(topAds) ? topAds : []; %>
<% const bottomList = Array.isArray(bottomAds) ? bottomAds : []; %>
<% const customList = Array.isArray(customAds) ? customAds : []; %>

<% if (leftList.length > 0) { %>
<div class="side-ad-slot side-ad-left scroll-locked">
    <% leftList.forEach((ad, i) => { %>
    <% let deviceClass = ''; if (ad.deviceTarget === 'desktop') { deviceClass = 'ad-desktop-only'; } if (ad.deviceTarget === 'mobile') { deviceClass = 'ad-mobile-only'; } %>
    <% let orientClass = 'ad-orient-' + (ad.orientation || 'vertical'); %>
    <a
        href="<%= ad.link || '#' %>"
        class="side-ad <%= i === 0 ? 'active' : '' %> <%= deviceClass %> <%= orientClass %>"
        data-rotate-ms="<%= (ad.rotateSeconds || 7) * 1000 %>"
        style="--ad-w:<%= ad.width || 160 %>px;--ad-h:<%= ad.height || 600 %>px;--ad-mw:<%= ad.mobileWidth || 320 %>px;--ad-mh:<%= ad.mobileHeight || 250 %>px;"
        target="_blank"
        rel="nofollow sponsored noopener"
        aria-label="Sol reklam alanı">
        <% const adMedia = ad.media || ad.image; %>
        <% if ((ad.mediaType === 'video') && adMedia) { %>
            <video src="<%= adMedia %>" autoplay muted loop playsinline preload="metadata"></video>
        <% } else { %>
            <img src="<%= adMedia %>" alt="<%= ad.name || 'Reklam' %>">
        <% } %>
    </a>
    <% }) %>
</div>
<% } %>

<% if (rightList.length > 0) { %>
<div class="side-ad-slot side-ad-right scroll-locked">
    <% rightList.forEach((ad, i) => { %>
    <% let deviceClass = ''; if (ad.deviceTarget === 'desktop') { deviceClass = 'ad-desktop-only'; } if (ad.deviceTarget === 'mobile') { deviceClass = 'ad-mobile-only'; } %>
    <% let orientClass = 'ad-orient-' + (ad.orientation || 'vertical'); %>
    <a
