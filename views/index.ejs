    <!-- Header -->
    <header class="header">
        <div class="container header-inner">
            <a href="/" class="logo">
                <img src="/logo.png" alt="59 Haber Kutusu" class="logo-img">
            </a>
            <button class="menu-toggle" id="menuToggle" aria-label="Menü">
                <span></span><span></span><span></span>
            </button>
            <nav class="nav" id="mainNav">
                <a href="/" class="nav-link active">Ana Sayfa</a>
                <a href="/kategori/son-dakika" class="nav-link">Son Dakika</a>
                <a href="/kategori/gundem" class="nav-link">Gündem</a>
                <a href="/kategori/ekonomi" class="nav-link">Ekonomi</a>
                <a href="/kategori/spor" class="nav-link">Spor</a>
                <a href="/kategori/siyaset" class="nav-link">Siyaset</a>
                <a href="/kategori/yasam" class="nav-link">Yaşam</a>
            </nav>
        </div>
    </header>
    <%- include('partials/side-ads') %>

    <!-- Breaking News Ticker -->
    <% if (heroNews.length > 0) { %>
    <div class="ticker">
        <div class="container ticker-inner">
            <span class="ticker-badge">SON DAKİKA</span>
            <div class="ticker-text">
                <span><%= heroNews.map(n => n.title).join(' \u2022 ') %></span>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Hero Slider -->
    <% if (heroNews.length > 0) { %>
    <section class="hero-slider">
        <div class="slider-track" id="sliderTrack">
            <% heroNews.forEach((item, i) => { %>
            <div class="slide <%= i === 0 ? 'active' : '' %>">
                <a href="/haber/<%= item.slug || item._id %>">
                    <div class="slide-img-wrap">
                        <img src="<%= item.image %>" alt="<%= item.title %>">
                        <div class="slide-overlay">
                            <span class="category-badge"><%= item.category %></span>
                            <h2 class="slide-title"><%= item.title %></h2>
                            <p class="slide-desc"><%= item.description %></p>
                            <p class="slide-meta"><%= item.createdAt.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>
        <button class="slider-btn slider-prev" id="sliderPrev" aria-label="Önceki">&#10094;</button>
        <button class="slider-btn slider-next" id="sliderNext" aria-label="Sonraki">&#10095;</button>
        <div class="slider-dots" id="sliderDots">
            <% heroNews.forEach((item, i) => { %>
            <button class="dot <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>"></button>
            <% }) %>
        </div>
    </section>
    <% } %>

    <!-- Çorlu Hava Durumu -->
    <section class="weather-widget" id="weatherCorlu">
        <div class="container">
            <div class="weather-box">
                <div class="weather-header">
                    <span class="weather-title">&#9728; Çorlu Hava Durumu</span>
                    <span class="weather-update" id="weatherUpdate"></span>
                </div>
                <div class="weather-content" id="weatherContent">
                    <div class="weather-loading" id="weatherLoading">Yükleniyor...</div>
                    <div class="weather-data" id="weatherData" style="display:none;">
                        <div class="weather-now">
                            <div class="weather-main">
                                <span class="weather-icon" id="weatherIcon" aria-hidden="true">&#9729;</span>
                                <div>
                                    <span class="weather-temp" id="weatherTemp">--</span>
                                    <span class="weather-unit">°C</span>
                                </div>
                            </div>
                            <div class="weather-detail">
                                <span class="weather-desc" id="weatherDesc">--</span>
                                <span class="weather-meta"><span id="weatherHumidity">--</span> nem · <span id="weatherWind">--</span> rüzgar</span>
                            </div>
                        </div>
                        <div class="weather-week-label">Bir haftalık rapor</div>
                        <div class="weather-week" id="weatherWeek"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Son Dakika Section -->
    <% if (sonDakika.length > 0) { %>
    <section class="section section-sondakika" id="son-dakika">
        <div class="container">
            <div class="section-header">
                <a href="/kategori/son-dakika" class="section-title-link">
                    <h2 class="section-title">Son Dakika</h2>
                    <span class="section-count"><%= sonDakikaCount %> haber</span>
                </a>
                <a href="/kategori/son-dakika" class="see-all">Tümünü Gör &rarr;</a>
            </div>
            <div class="news-grid">
                <% sonDakika.forEach(item => { %>
                <article class="news-card">
                    <a href="/haber/<%= item.slug || item._id %>">
                        <div class="card-img">
                            <img src="<%= item.image %>" alt="<%= item.title %>">
                        </div>
                        <div class="card-body">
                            <span class="card-date"><%= item.createdAt.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                            <h3 class="card-title"><%= item.title %></h3>
                            <p class="card-desc"><%= item.description %></p>
                        </div>
                    </a>
                </article>
                <% }) %>
            </div>
            <div class="section-more">
                <a href="/kategori/son-dakika" class="more-btn">Son Dakika Haberlerinin Tamamı &rarr;</a>
            </div>
        </div>
    </section>
    <% } %>

